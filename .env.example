# Base de datos Neon
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Cloudinary para imágenes
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# Servidor
PORT=3000
NODE_ENV=development

# JWT — usa al menos 64 caracteres aleatorios. Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# ── RSS Aggregator ──────────────────────────────────────────────────────────────
# Secreto para proteger endpoints de cron (/api/cron/fetch-rss, /api/cron/generate-briefing)
# El mismo valor debe usarse como header x-cron-secret en las llamadas desde cron-job.org
CRON_SECRET=cambia-esto-por-un-secreto-largo

# Configuración de IA (opcional, para briefing inteligente)
# GROQ_API_KEY=opcional
# AI_API_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.3-70b-versatile

# ── Scraping manual ────────────────────────────────────────────────────────────
# URL base para el scraper (producción)
# SITE_URL=https://epm.onrender.com
