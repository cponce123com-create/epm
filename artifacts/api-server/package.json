{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings 0 --ext .ts",
    "lint:fix": "eslint . --fix --max-warnings 0 --ext .ts",
    "scraper:run": "tsx src/scripts/manualScraper.ts",
    "scraper:fetch": "curl -X POST http://localhost:5000/api/cron/fetch-rss -H 'x-cron-secret: mi-secreto'",
    "cron:briefing": "curl -X POST http://localhost:5000/api/cron/generate-briefing -H 'x-cron-secret: mi-secreto'"
  },
  "dependencies": {
    "@sentry/node": "^10.54.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/external-news": "workspace:*",
    "adm-zip": "^0.5.10",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.0.0",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dompurify": "^3.4.2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-rate-limit": "^8.4.1",
    "fast-xml-parser": "^4.4.0",
    "file-type": "^22.0.1",
    "helmet": "^8.1.0",
    "jsdom": "^29.1.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pino": "^9",
    "pino-http": "^10",
    "slugify": "^1.6.9",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
